---
import Base from "../layouts/Base.astro";
import { desktopWallpaper, socials } from "../data/site";
import { experience, resumeHref } from "../data/tech";

// Dock socials — pull hrefs from site.ts so they stay editable in one place.
const socialByLabel = Object.fromEntries(socials.map((s) => [s.label, s]));
const linkedin = socialByLabel["LinkedIn"]?.href ?? "#";
const emailHref = "mailto:michelle001.xiang@gmail.com,mtxiang@mit.edu";
---

<Base theme="screen">
  <div class="fullbleed">
    <div class="desktop" id="desktop" style={`--wallpaper:${desktopWallpaper}`}>
      <!-- faux macOS menu bar -->
      <div class="menubar">
        <div class="mb-left">
          <span class="mb-apple">◍</span>
          <strong>Finder</strong>
          <span>File</span>
          <span>Edit</span>
          <span>View</span>
          <span>Go</span>
        </div>
        <div class="mb-right">
          <span class="mb-batt">100%</span>
          <span class="mb-clock" id="clock">—</span>
        </div>
      </div>

      <!-- desktop icons -->
      <div class="desk-icons">
        <button class="desk-icon" data-target="win-about">
          <span class="ic">📄</span><span class="ic-label">about-me</span>
        </button>
       
        <button class="desk-icon" data-target="win-experience">
          <span class="ic">📁</span><span class="ic-label">Experience</span>
        </button>
        <button class="desk-icon" data-target="win-projects">
          <span class="ic">📁</span><span class="ic-label">Projects</span>
        </button>
        <button class="desk-icon" data-target="win-favorites">
          <span class="ic">📁</span><span class="ic-label">Favorites</span>
        </button>
        <a class="desk-icon" href={resumeHref} target="_blank" rel="noopener">
          <span class="ic">📄</span><span class="ic-label">résumé.pdf</span>
        </a>
        <a class="desk-icon link" href="/photography/">
          <span class="ic">📁</span><span class="ic-label">Photography / Art</span>
        </a>
      </div>

      <!-- About window -->
      <section class="win win-text" id="win-about" style="left:36px; top:56px; width:590px;">
        <header class="win-bar">
          <span class="traffic">
            <i class="t-red" data-close="win-about"></i><i class="t-yellow"></i><i class="t-green"></i>
          </span>
          <span class="win-title">📄 about-me.txt</span>
        </header>
        <div class="win-body mono">
          <p>Hello! My name is Michelle.</p>
          <p>
            I recently graduated from MIT with a B.S. in
            <span class="hl">Mathematics</span> and
            <span class="hl">Artificial Intelligence &amp; Decision Making</span>,
            and a minor in
            <a class="hl" href="https://act.mit.edu/" target="_blank" rel="noopener">Art, Culture, and Technology</a>.
          </p>
          <p>
            In college, I dabbled in photojournalism and
            was the photo editor for V145 of
            <a href="https://thetech.com/" target="_blank" rel="noopener"><em>The Tech</em></a>,
            helped <a href="/photography/projects/mit-gala/">organize some fashion shows</a>,
            and contributed to a <a href="/photography/projects/infinite/">magazine</a>.
            Additionally, I worked on the
            <a href="https://technique.mit.edu/" target="_blank" rel="noopener">student yearbook</a>,
            danced with 
            <a href="https://www.youtube.com/user/MITAsianDanceTeam" target="_blank" rel="noopener">ADT</a>,
            and was an
            <a href="https://arts.mit.edu/start/arts-scholars/" target="_blank" rel="noopener">MIT Arts Scholar</a>.
          </p>
          <p class="about-intro">Some things I like to think about:</p>
          <ul class="about-list">
            <li>play and play drive</li>
            <li>the intersection of art and technology</li>
            <li>the act of documentation</li>
          </ul>

          <p 
          class="muted-line">currently: taking photos in NYC and figuring out what comes after MIT
        </p>
          <p>
            For photography and other visual work, take a look at the <a href="/photography/"> gallery wall →</a>
          </p>
        </div>
      </section>

      <!-- Projects window (placeholder) -->
      <section class="win win-text" id="win-projects" style="left:160px; top:140px; width:340px; display:none;">
        <header class="win-bar">
          <span class="traffic">
            <i class="t-red" data-close="win-projects"></i><i class="t-yellow"></i><i class="t-green"></i>
          </span>
          <span class="win-title">📁 Projects</span>
        </header>
        <div class="win-body mono">
          <p class="muted-line">work in progress!</p>
        </div>
      </section>

      {/* Full Projects window — to restore, add `techProjects` to the tech.ts
          import above, then replace the placeholder window with this one:
      <section class="win" id="win-projects" style="left:160px; top:140px; width:420px; display:none;">
        <header class="win-bar">
          <span class="traffic">
            <i class="t-red" data-close="win-projects"></i><i class="t-yellow"></i><i class="t-green"></i>
          </span>
          <span class="win-title">📁 Projects</span>
        </header>
        <div class="win-body">
          {
            techProjects.map((p) => (
              <a class="file-row" href={p.href ?? "#"} target="_blank" rel="noopener">
                <span class="fr-ico">📄</span>
                <div class="fr-main">
                  <div class="fr-name">{p.name}</div>
                  <div class="fr-blurb">{p.blurb}</div>
                  <div class="fr-stack">
                    {p.stack.map((s) => (
                      <span class="chip">{s}</span>
                    ))}
                  </div>
                </div>
                {p.kind && <div class="fr-kind">{p.kind}</div>}
              </a>
            ))
          }
        </div>
      </section>
      */}

      <!-- Favorites window -->
      <section class="win" id="win-favorites" style="left:430px; top:110px; width:320px; display:none;">
        <header class="win-bar">
          <span class="traffic">
            <i class="t-red" data-close="win-favorites"></i><i class="t-yellow"></i><i class="t-green"></i>
          </span>
          <span class="win-title">📁 Favorites</span>
        </header>
        <div class="win-body fav-list">
          <p class="fav-intro">a non-comprehensive list of some of my current favorites</p>
          <details class="fav-cat">
            <summary>music</summary>
            <div class="fav-body">
              <p class="fav-sub">some current favorite artists:</p>
              <ul>
                <li>edgehill</li>
                <li>5 seconds of summer</li>
                <li>day6</li>
                <li>flipturn</li>
                <li>noah kahan</li>
                <li>bon iver</li>
                <li>the poles</li>
              </ul>
              <p class="fav-sub">some current favorite songs:</p>
              <ul>
                <li>mango sticky rice by ggwendolyn</li>
                <li>bluetokyo by 87dance</li>
                <li>sick dogs by hey, nothing</li>
                <li>trophy hunting by eden</li>
                <li>heading south by zach bryan</li>
                <li>theory of emotion by del water gap</li>
                <li>circle the drain by soccer mommy</li>
                <li>blade bird by oklou</li>
                <li>cherry cola by devon again</li>
                <li>mangetout by wet leg</li>
                <li>feel this way by post sex nachos</li>
              </ul>
            </div>
          </details>
          <details class="fav-cat">
            <summary>films</summary>
            <div class="fav-body">
              <ul>
                <li>shaolin soccer (2001)</li>
                <li>perfumed nightmare (1977)</li>
                <li>chungking express (1994)</li>
                <li>dìdi (2024)</li>
                <li>project hail mary (2026)</li>
              </ul>
            </div>
          </details>
          <details class="fav-cat">
            <summary>shows</summary>
            <div class="fav-body">
              <ul>
                <li>mob psycho 100</li>
                <li>daredevil</li>
                <li>white collar</li>
              </ul>
            </div>
          </details>
          <details class="fav-cat">
            <summary>artists &amp; photographers</summary>
            <div class="fav-body">
              <ul>
                <li>raqib shaw</li>
                <li>gregory crewdson</li>
                <li>cho gi-seok</li>
                <li>win tam</li>
              </ul>
            </div>
          </details>
        </div>
      </section>

      <!-- Experience window (professional / tech) -->
      <section class="win" id="win-experience" style="left:64px; top:320px; width:660px; display:none;">
        <header class="win-bar">
          <span class="traffic">
            <i class="t-red" data-close="win-experience"></i><i class="t-yellow"></i><i class="t-green"></i>
          </span>
          <span class="win-title">📁 Experience</span>
        </header>
        <div class="win-body">
          {
            experience.map((r) => (
              <div class="exp-row">
                <div class="exp-when">{r.when}</div>
                <div class="exp-main">
                  <div class="exp-role">
                    <strong>{r.role}</strong> ·{" "}
                    {r.href ? (
                      <a href={r.href} target="_blank" rel="noopener">
                        {r.org}
                      </a>
                    ) : (
                      <span>{r.org}</span>
                    )}
                  </div>
                  <div class="exp-blurb">{r.blurb}</div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      {/* Campus Involvement window removed — folded into about-me.txt.
          Restore from tech.ts `campusInvolvement` (also commented out there). */}

      <!-- macOS dock -->
      <nav class="dock" aria-label="Dock">
        <button class="dock-item" data-target="win-about" aria-label="About me">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h8l4 4v16H6z"/><path d="M14 2v4h4"/><path d="M9 12h6M9 16h5"/></svg>
          <span class="dock-tip">about-me</span>
        </button>
        <a class="dock-item" href="/photography/" aria-label="Photography / Art">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h3l1.5-2h9L18 8h3v12H3z"/><circle cx="12" cy="13" r="3.4"/></svg>
          <span class="dock-tip">photography / art</span>
        </a>
        <a class="dock-item" href={resumeHref} target="_blank" rel="noopener" aria-label="Résumé">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h8l4 4v16H6z"/><path d="M14 2v4h4"/><path d="M9 13h6M9 17h6M9 9h2"/></svg>
          <span class="dock-tip">résumé</span>
        </a>
        <span class="dock-sep"></span>
        <a class="dock-item" href={emailHref} aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7.5 8.5 6 8.5-6"/></svg>
          <span class="dock-tip">email</span>
        </a>
        <a class="dock-item" href={linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21H9z"/></svg>
          <span class="dock-tip">linkedin</span>
        </a>
      </nav>
    </div>
  </div>
</Base>

<script>
  const desktop = document.getElementById("desktop") as HTMLElement;
  const dock = desktop.querySelector<HTMLElement>(".dock");
  const wins = [...desktop.querySelectorAll<HTMLElement>(".win")];
  const icons = [
    ...desktop.querySelectorAll<HTMLElement>("[data-target]"),
  ];

  // Cap a window's height so its bottom stays above the dock; the body scrolls
  // inside instead of the window growing past it (e.g. Favorites dropdowns).
  function clampToDock(win: HTMLElement) {
    const limit = dock ? dock.offsetTop : desktop.clientHeight;
    const avail = limit - win.offsetTop - 16;
    win.style.maxHeight = `${Math.max(130, avail)}px`;
  }

  let z = 10;
  function focusWin(win: HTMLElement) {
    win.style.zIndex = String(++z);
  }
  function openWin(id: string) {
    const win = document.getElementById(id);
    if (!win) return;
    win.style.display = "flex";
    clampToDock(win);
    focusWin(win);
  }
  icons.forEach((ic) => {
    const open = () => openWin(ic.dataset.target!);
    ic.addEventListener("click", open);
    ic.addEventListener("dblclick", open);
  });
  desktop.querySelectorAll<HTMLElement>("[data-close]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const win = document.getElementById(btn.dataset.close!);
      if (win) win.style.display = "none";
    });
  });

  wins.forEach((win) => {
    win.addEventListener("pointerdown", () => focusWin(win));
  });

  // clamp windows that are open on load, and re-clamp when the desktop resizes
  const clampVisible = () =>
    wins.forEach((w) => {
      if (w.style.display !== "none") clampToDock(w);
    });
  clampVisible();
  window.addEventListener("resize", clampVisible);

  // resize from any edge or corner
  const MIN_W = 240;
  const MIN_H = 130;
  wins.forEach((win) => {
    ["n", "s", "e", "w", "ne", "nw", "se", "sw"].forEach((dir) => {
      const h = document.createElement("div");
      h.className = `resize-h r-${dir}`;
      win.appendChild(h);
      h.addEventListener("pointerdown", (e) => {
        e.preventDefault();
        e.stopPropagation();
        focusWin(win);
        win.classList.add("resizing");
        try {
          h.setPointerCapture(e.pointerId);
        } catch {}
        const startX = e.clientX;
        const startY = e.clientY;
        const startW = win.offsetWidth;
        const startH = win.offsetHeight;
        const startL = win.offsetLeft;
        const startT = win.offsetTop;
        const onMove = (ev: PointerEvent) => {
          const dx = ev.clientX - startX;
          const dy = ev.clientY - startY;
          let w = startW,
            ht = startH,
            l = startL,
            t = startT;
          if (dir.includes("e")) w = Math.max(MIN_W, startW + dx);
          if (dir.includes("s")) ht = Math.max(MIN_H, startH + dy);
          if (dir.includes("w")) {
            w = Math.max(MIN_W, startW - dx);
            l = startL + (startW - w);
          }
          if (dir.includes("n")) {
            ht = Math.max(MIN_H, startH - dy);
            t = startT + (startH - ht);
          }
          win.style.width = `${w}px`;
          win.style.height = `${ht}px`;
          win.style.left = `${l}px`;
          win.style.top = `${t}px`;
        };
        const onUp = () => {
          win.classList.remove("resizing");
          document.removeEventListener("pointermove", onMove);
          document.removeEventListener("pointerup", onUp);
        };
        document.addEventListener("pointermove", onMove);
        document.addEventListener("pointerup", onUp);
      });
    });
  });

  // drag by titlebar
  let active: HTMLElement | null = null;
  let sx = 0,
    sy = 0,
    ol = 0,
    ot = 0;
  wins.forEach((win) => {
    const bar = win.querySelector(".win-bar") as HTMLElement;
    bar.addEventListener("pointerdown", (e) => {
      if ((e.target as HTMLElement).closest(".traffic")) return;
      active = win;
      sx = e.clientX;
      sy = e.clientY;
      ol = win.offsetLeft;
      ot = win.offsetTop;
      focusWin(win);
      bar.setPointerCapture(e.pointerId);
      win.classList.add("dragging");
    });
    bar.addEventListener("pointermove", (e) => {
      if (active !== win) return;
      const W = desktop.clientWidth;
      const H = desktop.clientHeight;
      let left = ol + (e.clientX - sx);
      let top = ot + (e.clientY - sy);
      left = Math.max(-win.offsetWidth + 80, Math.min(W - 80, left));
      top = Math.max(28, Math.min(H - 36, top));
      win.style.left = `${left}px`;
      win.style.top = `${top}px`;
    });
    const end = () => {
      if (active === win) win.classList.remove("dragging");
      active = null;
    };
    bar.addEventListener("pointerup", end);
    bar.addEventListener("pointercancel", end);
  });

  // live clock
  const clock = document.getElementById("clock");
  function tick() {
    if (!clock) return;
    clock.textContent = new Date().toLocaleString(undefined, {
      weekday: "short",
      hour: "numeric",
      minute: "2-digit",
    });
  }
  tick();
  setInterval(tick, 15000);
</script>
