---
import "../styles/global.css";
import { site, nav } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  theme?: "paper" | "screen";
}

const { title, description, theme = "paper" } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.title;
const pageDesc = description ?? site.description;

// Normalize current path for active-nav highlighting (trailing slash agnostic).
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body data-theme={theme}>
    <header class="wrap site-header">
      <a class="brand" href="/">{site.name}</a>
      <nav class="nav" aria-label="Primary">
        {
          nav.map((item) => {
            const href = item.href.replace(/\/+$/, "") || "/";
            const active = href === current;
            return (
              <a href={item.href} aria-current={active ? "page" : undefined}>
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="wrap site-footer">
      <span>© {new Date().getFullYear()} {site.name}</span>
      <span>Built with Astro</span>
    </footer>
  </body>
</html>
